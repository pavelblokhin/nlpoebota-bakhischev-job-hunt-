APP_NAME=HR Career Assistant
APP_ENV=dev
LOG_LEVEL=INFO

# Токен от @BotFather. Скопируй этот файл в .env и подставь значения (не коммить .env).
TELEGRAM_BOT_TOKEN=
LLM_API_KEY=
LLM_MODEL=Qwen3.5-Flash
LLM_PROVIDER=mock
LLM_DEVICE=auto
LLM_MAX_NEW_TOKENS=384
LLM_TEMPERATURE=0.2

EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
EMBEDDING_DEVICE=auto
SQLITE_PATH=data/app.db
FAISS_INDEX_PATH=data/faiss/vacancies.index
VACANCIES_PATH=data/mock_vacancies.json

USE_MOCK_LLM=true
USE_MOCK_EMBEDDINGS=true
PRELOAD_MODELS_ON_STARTUP=true
